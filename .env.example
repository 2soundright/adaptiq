# ── Groq API ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq model IDs
GROQ_GENERATION_MODEL=llama-3.3-70b-versatile
GROQ_TRANSFORM_MODEL=llama-3.1-8b-instant
GROQ_SAFETY_MODEL=llama-guard-3-8b
GROQ_FEEDBACK_MODEL=llama-3.1-8b-instant

# ── HuggingFace Inference API ─────────────────────────────────────────────────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_EMBEDDING_MODEL=BAAI/bge-m3
HF_RERANKER_MODEL=BAAI/bge-reranker-large

# ── Security ──────────────────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App ───────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=admin
DEFAULT_USER_PASSWORD=user
DEFAULT_COMPANY_ID=1
DEFAULT_COMPANY_NAME=pendo
DEFAULT_COMPANY_WEBSITE=https://www.pendo.io
